{
    "mcpServers": {
        "filesystem": {
            "type": "local",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
            "tools": ["*"]
        },
        "context7": {
            "type": "local",
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp"],
            "tools": ["*"]
        },
        "book-lookup": {
            "type": "local",
            "command": "python3",
            "args": ["./book-app-mcp-server/server.py"],
            "tools": ["*"]
        }
    }
}